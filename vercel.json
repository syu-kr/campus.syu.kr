{
  "rewrites": [
    {
      "source": "/bus/shuttle",
      "destination": "http://nexmotion.co.kr/bus/busStatusList.php"
    }
  ],
  "headers": [
    {
      "source": "/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate, max-age=0"
        }
      ]
    }
  ]
}
