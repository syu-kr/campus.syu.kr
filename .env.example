# ============================================================================
# Environment Variables Configuration
# Copy this file to .env.local and fill in your values
# ============================================================================

# ============================================================================
# Kakao Maps API
# Get API key from: https://developers.kakao.com/
# ============================================================================
NEXT_PUBLIC_KAKAO_MAP_KEY=your_kakao_map_api_key_here

# ============================================================================
# Server-side external API settings
# Keep these values on the server. Do not prefix them with NEXT_PUBLIC_.
# Register the same values in Vercel Project Environment Variables.
# ============================================================================
PUBLIC_DATA_SERVICE_KEY=your_public_data_service_key_here
KMA_NCST_URL=your_kma_ultra_short_nowcast_endpoint
KMA_FCST_URL=your_kma_ultra_short_forecast_endpoint
SEOUL_BUS_ARRIVAL_URL=your_seoul_bus_arrival_endpoint
GYEONGGI_BUS_ARRIVAL_URL=your_gyeonggi_bus_arrival_endpoint
GYEONGGI_BUS_LOCATION_URL=your_gyeonggi_bus_location_endpoint
SHUTTLE_LOCATION_URL=your_shuttle_location_endpoint
SHUTTLE_REFERER=your_shuttle_referer_origin
SHUTTLE_USER_AGENT=your_shuttle_request_user_agent
LECTURE_TIMETABLE_URL=your_lecture_timetable_endpoint
LIBRARY_READING_ROOMS_URL=your_library_reading_rooms_endpoint

# ============================================================================
# Firebase Configuration (Client-side)
# Get values from Firebase Console → Project Settings
# These values are PUBLIC and safe to expose to browser
# ============================================================================
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# ============================================================================
# Firebase Web Push (VAPID KEY)
# Used for web push notifications in service worker
# ============================================================================
NEXT_PUBLIC_FIREBASE_VAPID_KEY=your-vapid-public-key-here

# ============================================================================
# Firebase Admin SDK (Server-side)
# IMPORTANT: Keep these values SECRET - never commit to git
# Base64 encoded version of Firebase service account JSON
# ============================================================================
FIREBASE_ADMIN_SDK_KEY=base64_encoded_firebase_service_account_json

# ============================================================================
# Firebase Service Account (Alternative format)
# Full JSON service account object as environment variable
# Use this for server-side Firebase operations
# ============================================================================
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"your-project","private_key":"..."}

# ============================================================================
# Push Notification API
# Internal API key for push notification authorization
# ============================================================================
PUSH_API_KEY=your_internal_push_notification_api_key

# ============================================================================
# Admin access allowlist
# Comma-separated Firebase Auth email addresses allowed to use admin APIs.
# If empty, any authenticated Firebase user can access admin APIs.
# ============================================================================
ADMIN_EMAILS=admin@example.com

# ============================================================================
# Application URLs
# Set these for GitHub Actions and deployment environments
# ============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
API_URL=http://localhost:3000

# For production/staging deployments:
# NEXT_PUBLIC_APP_URL=https://syu-campus.vercel.app
# NEXT_PUBLIC_APP_URL=https://staging.syu-campus.com

# ============================================================================
# Optional maintenance/build flags
# ============================================================================
TOKEN_CLEANUP_DAYS=90
ANALYZE=false

# ============================================================================
# Local crawler source URLs
# GitHub Actions should receive these through repository Actions Variables.
# Locally, set them in your shell before running crawler scripts.
# ============================================================================
CRAWL_ACADEMIC_NOTICES_URL=your_academic_notice_board_page_base_url
CRAWL_SCHOLARSHIP_NOTICES_URL=your_scholarship_notice_board_page_base_url
CRAWL_EVENT_NOTICES_URL=your_event_notice_board_page_base_url
CRAWL_CAMPUS_NOTICES_URL=your_campus_notice_board_page_base_url
CRAWL_CAFETERIA_URL=your_cafeteria_page_url
CRAWL_PHONE_DIRECTORY_URL=your_phone_directory_page_url
CRAWL_ACADEMIC_SCHEDULE_URL=your_academic_schedule_page_url
CRAWL_GRAD_BUSINESS_URL=your_graduation_business_page_url
CRAWL_GRAD_GLOBAL_KOREAN_URL=your_graduation_global_korean_page_url
CRAWL_GRAD_COMPUTER_SCIENCE_URL=your_graduation_computer_science_page_url
CRAWL_GRAD_NURSING_URL=your_graduation_nursing_page_url
CRAWL_GRAD_PHARMACY_URL=your_graduation_pharmacy_page_url
CRAWL_GRAD_ARCHITECTURE_URL=your_graduation_architecture_page_url
CRAWL_GRAD_AI_URL=your_graduation_ai_page_url
