{
  "name": "syu-campus",
  "version": "1.0.0",
  "packageManager": "npm@10.9.4",
  "description": "삼육대학교 통합 정보 플랫폼 - 공지사항, 학식, 학사일정 한눈에 확인",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "overrides": {
    "minimatch@^3.0.0": {
      "brace-expansion": "1.1.16"
    },
    "minimatch@^10.0.0": {
      "brace-expansion": "5.0.7"
    },
    "postcss": "8.5.22",
    "protobufjs": "7.6.5",
    "sharp": "0.35.3",
    "uuid": "11.1.1"
  },
  "knip": {
    "ignoreBinaries": [
      "python"
    ]
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:analyze": "node scripts/build-analyze.mjs",
    "start": "next start",
    "lint": "eslint .",
    "type-check": "tsc --noEmit --incremental false",
    "check:i18n": "node scripts/check_i18n_strings.mjs",
    "check:unused": "knip",
    "check:python": "python scripts/check_python_syntax.py",
    "check:graduation": "node scripts/check_graduation_data.mjs",
    "check:curriculum": "node scripts/check_curriculum_data.mjs",
    "check:crawl-data": "ts-node --files --project tsconfig.json scripts/publish-crawl-data.ts --dry-run",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "audit:curriculum": "python scripts/audit_curriculum_courses.py",
    "build:verified-curriculum": "python scripts/build_verified_curriculum.py",
    "generate:announcement-ai": "node scripts/generate_announcement_ai_summaries.mjs",
    "pull:crawl-data": "ts-node --files --project tsconfig.json scripts/publish-crawl-data.ts --pull-current",
    "prepare:crawl-data-pages": "ts-node --files --project tsconfig.json scripts/publish-crawl-data.ts --prepare-pages",
    "rollback:crawl-data": "ts-node --files --project tsconfig.json scripts/publish-crawl-data.ts --rollback",
    "check": "npm run lint && npm run type-check && npm run check:i18n && npm run check:unused && npm run check:python && npm run check:graduation && npm run check:curriculum && npm run check:crawl-data && npm run test:unit && npm run build",
    "send-daily-notification": "ts-node --project tsconfig.json scripts/send-daily-notification.ts",
    "cleanup-tokens": "ts-node --project tsconfig.json scripts/cleanup_old_tokens.ts",
    "cleanup-expired-firestore": "ts-node --project tsconfig.json scripts/cleanup_meet_rooms.ts",
    "cleanup-meet-rooms": "ts-node --project tsconfig.json scripts/cleanup_meet_rooms.ts",
    "backfill-meet-participant-expiry": "ts-node --project tsconfig.json scripts/backfill_meet_participant_expiry.ts",
    "notification-lock": "ts-node --project tsconfig.json scripts/notification_send_lock.ts"
  },
  "dependencies": {
    "@fontsource/pretendard": "^5.2.5",
    "@tanstack/react-query": "^5.101.1",
    "clsx": "^2.1.0",
    "firebase": "^12.16.0",
    "firebase-admin": "^13.10.0",
    "next": "^16.2.11",
    "react": "^19.2.7",
    "react-dom": "^19.2.8",
    "react-markdown": "^10.1.0"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.11",
    "@tailwindcss/postcss": "^4.3.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "22.13.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.11",
    "jsdom": "^29.1.1",
    "knip": "^6.25.0",
    "postcss": "8.5.22",
    "tailwindcss": "^4.3.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
