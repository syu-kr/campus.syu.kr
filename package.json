{
  "name": "syu-campus",
  "version": "1.0.0",
  "packageManager": "npm@10.9.4",
  "description": "삼육대학교 통합 정보 플랫폼 - 공지사항, 학식, 학사일정 한눈에 확인",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "overrides": {
    "postcss": "8.5.15",
    "uuid": "11.1.1"
  },
  "knip": {
    "ignoreBinaries": [
      "python"
    ]
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:analyze": "node scripts/build-analyze.mjs",
    "start": "next start",
    "lint": "eslint .",
    "type-check": "tsc --noEmit --incremental false",
    "check:i18n": "node scripts/check_i18n_strings.mjs",
    "check:unused": "knip",
    "check:python": "python scripts/check_python_syntax.py",
    "check:graduation": "node scripts/check_graduation_data.mjs",
    "check:curriculum": "node scripts/check_curriculum_data.mjs",
    "audit:curriculum": "python scripts/audit_curriculum_courses.py",
    "build:verified-curriculum": "python scripts/build_verified_curriculum.py",
    "generate:announcement-ai": "node scripts/generate_announcement_ai_summaries.mjs",
    "check": "npm run lint && npm run type-check && npm run check:i18n && npm run check:unused && npm run check:python && npm run check:graduation && npm run check:curriculum && npm run build",
    "send-daily-notification": "ts-node --project tsconfig.json scripts/send-daily-notification.ts",
    "cleanup-tokens": "ts-node --project tsconfig.json scripts/cleanup_old_tokens.ts",
    "cleanup-expired-firestore": "ts-node --project tsconfig.json scripts/cleanup_meet_rooms.ts",
    "cleanup-meet-rooms": "ts-node --project tsconfig.json scripts/cleanup_meet_rooms.ts",
    "backfill-meet-participant-expiry": "ts-node --project tsconfig.json scripts/backfill_meet_participant_expiry.ts",
    "notification-lock": "ts-node --project tsconfig.json scripts/notification_send_lock.ts"
  },
  "dependencies": {
    "@fontsource/pretendard": "^5.2.5",
    "@tanstack/react-query": "^5.28.0",
    "clsx": "^2.1.0",
    "firebase": "^12.11.0",
    "firebase-admin": "^13.6.0",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.9",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "knip": "^6.16.1",
    "postcss": "8.5.15",
    "tailwindcss": "^4.3.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
